{
  "name": "headless-wp",
  "version": "0.1.0",
  "description": "Headless WordPress with Next.js 16 and Tailwind CSS v4",
  "private": true,
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
  "scripts": {
    "dev": "pnpm wp:start && wait-on http://localhost:8888 && turbo run dev --filter=@headless-wp/frontend",
    "dev:next": "turbo run dev --filter=@headless-wp/frontend",
    "build": "turbo run build",
    "start": "turbo run start --filter=@headless-wp/frontend",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "turbo run lint",
    "lint:fix": "biome check --write .",
    "lint:next": "turbo run lint --filter=@headless-wp/frontend",
    "wp:start": "pnpm --filter wordpress start",
    "wp:stop": "pnpm --filter wordpress stop",
    "wp:info": "pnpm --filter wordpress info",
    "wp:setup": "cd apps/wordpress && npx wp-env run cli wp rewrite structure '/%postname%/' --hard && npx wp-env run cli wp rewrite flush --hard"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.4",
    "concurrently": "^8.2.2",
    "lefthook": "^2.1.9",
    "turbo": "^2.9.16",
    "wait-on": "^7.2.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "keywords": [
    "headless",
    "wordpress",
    "nextjs",
    "react",
    "typescript",
    "tailwindcss",
    "rest-api"
  ],
  "license": "MIT"
}
