  # WordPress base URL (Docker wp-env default: port 8888)
  NEXT_PUBLIC_WP_URL=http://localhost:8888

  # WordPress REST API v2 base URL
  NEXT_PUBLIC_WP_API_URL=http://localhost:8888/wp-json/wp/v2

  Draft Mode用にこれを追記する必要があります：

  # Draft Mode (プレビュー機能)
  # .wp-env.json の PREVIEW_SECRET と同じ値を設定
  PREVIEW_SECRET=your-preview-secret-here

  # WordPress アプリケーションパスワード (下書きプレビュー取得用)
  # WordPress管理画面 > ユーザー > プロフィール > アプリケーションパスワード で生成
  WP_APPLICATION_PASSWORD=
