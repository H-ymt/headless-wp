# WordPress base URL (Docker wp-env default: port 8888)
NEXT_PUBLIC_WP_URL=http://localhost:8888

# WordPress REST API v2 base URL
NEXT_PUBLIC_WP_API_URL=http://localhost:8888/wp-json/wp/v2

# JWT Authentication endpoint
# Requires "JWT Authentication for WP REST API" plugin to be active (automated via afterStart)
NEXT_PUBLIC_WP_JWT_URL=http://localhost:8888/wp-json/jwt-auth/v1
