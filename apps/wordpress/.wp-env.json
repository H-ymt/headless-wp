{
  "core": "https://ja.wordpress.org/latest-ja.zip",
  "phpVersion": "8.3",
  "plugins": [],
  "themes": [],
  "port": 8888,
  "testsPort": 8889,
  "config": {
    "WP_DEBUG": true,
    "WP_DEBUG_LOG": true,
    "SCRIPT_DEBUG": true
  },
  "mappings": {
    "wp-content/plugins": "./wp-content/plugins",
    "wp-content/themes": "./wp-content/themes"
  },
  "afterStart": [
    "wp rewrite structure '/%postname%/' --hard",
    "wp rewrite flush --hard"
  ]
}
